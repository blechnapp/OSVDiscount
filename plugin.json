{
    "name": "OSVDiscount",
    "namespace": "OSVDiscount",
    "type": "template",
    "version": "1.6.0",
    "license": "proprietary",
    "description": "Zeigt einen Rabatt-Prozent-Banner auf der Artikeleinzelansicht an.",
    "shortDescription": {
        "de": "Rabatt-Prozent-Banner fuer die Artikeleinzelansicht",
        "en": "Discount percentage banner for single item view"
    },
    "author": "Seiffener Volkskunst eG",
    "keywords": ["rabatt", "discount", "banner"],
    "require": {
        "Ceres": ">=5.0.0",
        "IO": ">=5.0.0"
    },
    "dependencies": [],
    "serviceProvider": "OSVDiscount\\Providers\\OSVDiscountServiceProvider",
    "dataProviders": [
        {
            "key": "OSVDiscount\\Containers\\DiscountBannerContainer",
            "name": "OSV Rabatt-Banner",
            "description": "Zeigt den Rabatt-Prozent-Banner an.",
            "defaultLayoutContainer": "Ceres::SingleItem.BeforePrice"
        }
    ]
}
